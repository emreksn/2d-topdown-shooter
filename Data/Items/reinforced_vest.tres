[ext_resource type="Script" uid="uid://dma8duyo44scc" path="res://Scripts/Stats/stat_modifier.gd" id="3_modifier"]

[sub_resource type="Resource" id="Health"]
script = ExtResource("3_modifier")
stat_id = &"maximum_health"
value = 18.0
target_domain = &"player"

[sub_resource type="Resource" id="Toughness"]
script = ExtResource("3_modifier")
