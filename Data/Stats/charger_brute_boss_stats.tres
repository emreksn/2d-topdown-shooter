[gd_resource type="Resource" script_class="StatProfile" format=3]

[ext_resource type="Script" path="res://Scripts/Stats/stat_profile.gd" id="1_profile"]
[ext_resource type="Script" path="res://Scripts/Stats/stat_value.gd" id="2_value"]

[sub_resource type="Resource" id="Health"]
script = ExtResource("2_value")
stat_id = &"maximum_health"
value = 1200.0

[sub_resource type="Resource" id="Movement"]
script = ExtResource("2_value")
stat_id = &"movement_speed"
value = 82.0

[sub_resource type="Resource" id="Contact"]
script = ExtResource("2_value")
stat_id = &"melee_damage"
value = 22.0

[sub_resource type="Resource" id="Toughness"]
script = ExtResource("2_value")
stat_id = &"toughness"
value = 10.0

[sub_resource type="Resource" id="Effectiveness"]
script = ExtResource("2_value")
stat_id = &"monster_effectiveness"
value = 80.0

[sub_resource type="Resource" id="Experience"]
script = ExtResource("2_value")
stat_id = &"experience_granted_multiplier"
value = 1.0

[sub_resource type="Resource" id="Gold"]
script = ExtResource("2_value")
stat_id = &"gold_granted_multiplier"
value = 1.0

[sub_resource type="Resource" id="Quantity"]
script = ExtResource("2_value")
stat_id = &"item_quantity_multiplier"
value = 10.0

[sub_resource type="Resource" id="Rarity"]
script = ExtResource("2_value")
stat_id = &"monster_item_rarity_multiplier"
value = 3.0

[sub_resource type="Resource" id="RelicDrops"]
script = ExtResource("2_value")
stat_id = &"monster_relic_drop_chance_multiplier"
value = 4.0

[sub_resource type="Resource" id="WeaponDrops"]
script = ExtResource("2_value")
stat_id = &"monster_weapon_drop_chance_multiplier"
value = 4.0

[sub_resource type="Resource" id="SkillDrops"]
script = ExtResource("2_value")
stat_id = &"monster_active_skill_drop_chance_multiplier"
value = 4.0

[resource]
script = ExtResource("1_profile")
values = Array[ExtResource("2_value")]([SubResource("Health"), SubResource("Movement"), SubResource("Contact"), SubResource("Toughness"), SubResource("Effectiveness"), SubResource("Experience"), SubResource("Gold"), SubResource("Quantity"), SubResource("Rarity"), SubResource("RelicDrops"), SubResource("WeaponDrops"), SubResource("SkillDrops")])
