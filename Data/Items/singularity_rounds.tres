[gd_resource type="Resource" script_class="ItemDefinition" format=3 uid="uid://ynwdxl8qjloq"]

[ext_resource type="Script" uid="uid://d11nsmii062xg" path="res://Scripts/Items/item_definition.gd" id="1_item"]
[ext_resource type="Script" uid="uid://buyyui2cjuh6k" path="res://Scripts/Stats/modifier_set.gd" id="2_set"]
[ext_resource type="Script" uid="uid://dma8duyo44scc" path="res://Scripts/Stats/stat_modifier.gd" id="3_modifier"]

[sub_resource type="Resource" id="Damage"]
script = ExtResource("3_modifier")
stat_id = &"damage"
operation = 1
value = 30.0
target_domain = &"player"

[sub_resource type="Resource" id="AttackRate"]
script = ExtResource("3_modifier")
stat_id = &"attack_rate"
operation = 1
value = 20.0
scope = 1
target_domain = &"weapon"

[sub_resource type="Resource" id="ProjectileSpeed"]
script = ExtResource("3_modifier")
stat_id = &"projectile_speed"
operation = 1
value = 16.0
scope = 1
target_domain = &"weapon"

[sub_resource type="Resource" id="ShopItemRarity"]
script = ExtResource("3_modifier")
stat_id = &"shop_item_rarity_multiplier"
operation = 1
value = 20.0
target_domain = &"player"

[sub_resource type="Resource" id="Modifiers"]
script = ExtResource("2_set")
modifiers = Array[ExtResource("3_modifier")]([SubResource("Damage"), SubResource("AttackRate"), SubResource("ProjectileSpeed"), SubResource("ShopItemRarity")])

[resource]
script = ExtResource("1_item")
id = &"singularity_rounds"
display_name = "Singularity Rounds"
description = "30% increased damage
20% increased attack rate
16% increased projectile speed
20% increased shop item rarity"
