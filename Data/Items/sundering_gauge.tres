[gd_resource type="Resource" script_class="ItemDefinition" format=3]

[ext_resource type="Script" path="res://Scripts/Items/item_definition.gd" id="1_item"]
[ext_resource type="Script" path="res://Scripts/Stats/modifier_set.gd" id="2_set"]
[ext_resource type="Script" path="res://Scripts/Stats/stat_modifier.gd" id="3_modifier"]

[sub_resource type="Resource" id="ArmourPenetration"]
script = ExtResource("3_modifier")
stat_id = &"armour_penetration"
value = 220.0
target_domain = &"player"

[sub_resource type="Resource" id="Accuracy"]
script = ExtResource("3_modifier")
stat_id = &"accuracy"
value = 80.0
target_domain = &"player"

[sub_resource type="Resource" id="Modifiers"]
script = ExtResource("2_set")
modifiers = Array[ExtResource("3_modifier")]([SubResource("ArmourPenetration"), SubResource("Accuracy")])

[resource]
script = ExtResource("1_item")
id = &"sundering_gauge"
display_name = "Sundering Gauge"
description = "+220 to armour penetration\n+80 to accuracy"
rarity = 3
cost = 58
modifier_set = SubResource("Modifiers")
