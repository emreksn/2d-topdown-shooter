[gd_resource type="Resource" script_class="ContentVariantDefinition" format=3 uid="uid://whxqc7x72kqw"]

[ext_resource type="Script" uid="uid://xbu8mq1tdese" path="res://Scripts/Content/content_variant_definition.gd" id="1_variant"]
[ext_resource type="Script" uid="uid://buyyui2cjuh6k" path="res://Scripts/Stats/modifier_set.gd" id="2_set"]
[ext_resource type="Script" uid="uid://dma8duyo44scc" path="res://Scripts/Stats/stat_modifier.gd" id="3_modifier"]

[sub_resource type="Resource" id="Quantity"]
script = ExtResource("3_modifier")
stat_id = &"item_quantity_multiplier"
operation = 1
value = 45.0
target_domain = &"monster"
required_all_tags = Array[StringName]([&"rift"])

[sub_resource type="Resource" id="Rarity"]
script = ExtResource("3_modifier")
stat_id = &"monster_item_rarity_multiplier"
operation = 1
value = 35.0
target_domain = &"monster"
required_all_tags = Array[StringName]([&"rift"])

[sub_resource type="Resource" id="Health"]
script = ExtResource("3_modifier")
stat_id = &"maximum_health"
operation = 1
value = 25.0
target_domain = &"monster"
required_all_tags = Array[StringName]([&"rift"])

[sub_resource type="Resource" id="Contact"]
script = ExtResource("3_modifier")
stat_id = &"melee_damage"
operation = 1
value = 10.0
target_domain = &"monster"
required_all_tags = Array[StringName]([&"rift"])

[sub_resource type="Resource" id="ModifierSet"]
script = ExtResource("2_set")
modifiers = Array[ExtResource("3_modifier")]([SubResource("Quantity"), SubResource("Rarity"), SubResource("Health"), SubResource("Contact")])

[resource]
script = ExtResource("1_variant")
id = &"bountiful"
display_name = "Bountiful"
inherent_modifier_set = SubResource("ModifierSet")
